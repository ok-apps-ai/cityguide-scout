{
  "coverageDirectory": "../coverage",
  "coveragePathIgnorePatterns": [
    "\\.entity\\.ts$",
    "collector/google/places/places\\.service\\.ts",
    "collector/osm/places/places\\.service\\.ts"
  ],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "preset": "ts-jest",
  "rootDir": "src",
  "testMatch": ["**/*.unit.spec.ts", "**/*.e2e.spec.ts", "**/*.integration.spec.ts"],
  "testTimeout": 120000,
  "transform": {
    "^.+\\.[tj]sx?$": [
      "ts-jest",
      {
        "tsconfig": "./tsconfig.spec.json"
      }
    ]
  }
}
